# ==============================================
# БЛОК ЗАПУСКА ПРИЛОЖЕНИЯ (RUN COMMAND)
# ==============================================
run = ["python", "manage.py", "runserver", "0.0.0.0:5000"]
# Команда запуска: запускает Django-сервер на порту 5000
# Доступен для всех сетевых интерфейсов (0.0.0.0)

# ==============================================
# БЛОК ТОЧКИ ВХОДА
# ==============================================
entrypoint = "manage.py"
# Главный файл для запуска приложения

# ==============================================
# БЛОК МОДУЛЕЙ (СРЕДА ВЫПОЛНЕНИЯ)
# ==============================================
modules = ["python-3.10:v18-20230807-322e88b"]
# Используемая версия Python и образ окружения
# Определяет предустановленные пакеты в Replit

# ==============================================
# БЛОК СКРЫТЫХ ПАПОК
# ==============================================
hidden = [".pythonlibs"]
# Папки, которые НЕ отображаются в файловом менеджере Replit
# .pythonlibs - содержит установленные Python-пакеты

# ==============================================
# БЛОК NIX-ПАКЕТОВ
# ==============================================
[nix]
channel = "stable-24_05"
# Канал Nix-пакетов для системных зависимостей
# stable-24_05 - стабильный релиз от мая 2024 года

# ==============================================
# БЛОК ЮНИТ-ТЕСТИРОВАНИЯ
# ==============================================
[unitTest]
language = "python3"
# Язык для запуска тестов (используется для автоматического тестирования)

# ==============================================
# БЛОК РАЗВЁРТЫВАНИЯ (DEPLOYMENT)
# ==============================================
[deployment]
run = ["python", "manage.py", "runserver", "0.0.0.0:5000"]
deploymentTarget = "gce"
# Цель развёртывания: Google Compute Engine (GCE)
# Команда запуска в продакшн-среде

# ==============================================
# БЛОК НАСТРОЙКИ ПОРТОВ
# ==============================================
[[ports]]
localPort = 5000
externalPort = 80
# Проброс портов:
# - Локальный порт контейнера: 5000 (Django)
# - Внешний порт (доступ извне): 80 (HTTP)
# Таким образом, сайт доступен на стандартном HTTP-порту

# ==============================================
# БЛОК НАСТРОЕК АГЕНТА
# ==============================================
[agent]
expertMode = true
# Включение экспертного режима для AI-агента Replit
# Даёт расширенный доступ к возможностям IDE

# ==============================================
# БЛОК НАСТРОЕК РАБОЧИХ ПРОЦЕССОВ (WORKFLOWS)
# ==============================================
[workflows]
runButton = "Project"
# Название кнопки запуска в интерфейсе Replit

# ==============================================
# ПЕРВЫЙ РАБОЧИЙ ПРОЦЕСС: PROJECT
# ==============================================
[[workflows.workflow]]
name = "Project"
mode = "parallel"           # Параллельное выполнение задач
author = "agent"            # Автор - AI-агент

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"  # Вызов другого workflow

# ==============================================
# ВТОРОЙ РАБОЧИЙ ПРОЦЕСС: START APPLICATION
# ==============================================
[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py runserver 0.0.0.0:5000"
waitForPort = 5000          # Ожидание запуска сервера на порту 5000

# ==============================================
# БЛОК МЕТАДАННЫХ WORKFLOW
# ==============================================
[workflows.workflow.metadata]
outputType = "webview"      # Вывод в веб-окно (браузер)
# При запуске открывается встроенный браузер Replit